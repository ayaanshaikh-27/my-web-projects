<!-- SKILLS -->
<section class="skills-section" id="skills">
  <div class="section-label">Expertise</div>
  <h2 class="section-title fade-up">What I Bring<br>to the Table</h2>
  <p class="section-sub fade-up">Specialised in modern frontend technologies, from pixel-perfect UI to scalable architecture.</p>

  <div class="skills-grid">
    <div class="skill-card fade-up">
      <div class="skill-icon">⚛️</div>
      <div class="skill-title">UI Development</div>
      <div class="skill-desc">Building responsive, accessible, and high-performance user interfaces that delight users across all devices.</div>
      <div class="skill-tags">
        <span class="tag">React</span>
        <span class="tag">Next.js</span>
        <span class="tag">TypeScript</span>
        <span class="tag">Tailwind</span>
      </div>
    </div>
    <div class="skill-card fade-up">
      <div class="skill-icon">🎨</div>
      <div class="skill-title">Design Systems</div>
      <div class="skill-desc">Creating scalable component libraries and design tokens that keep products consistent and maintainable.</div>
      <div class="skill-tags">
        <span class="tag">Storybook</span>
        <span class="tag">Figma</span>
        <span class="tag">CSS-in-JS</span>
        <span class="tag">Radix UI</span>
      </div>
